import java.util.*;
public class Main
{
	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
        int n=sc.nextInt();
        int temp=n;
        int sum=0;
        while(n!=0){
            int digit=n%10;
            sum+=digit;
            n=n/10;
        }
        if(temp%sum==0) System.out.print("The given number is a harshad number");
        else System.out.print("The given number is not a harshad number");
	}
}